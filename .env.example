# ========================================
# Server Configuration
# ========================================
NODE_ENV=development
PORT=5000
IP_ADDRESS=localhost
BACKEND_URL=http://localhost:5000
FRONTEND_URL=http://localhost:3000

# ========================================
# Database Configuration
# ========================================
DATABASE_URL=mongodb://localhost:27017/your-database-name

# ========================================
# Security & Encryption
# ========================================
BCRYPT_SALT_ROUNDS=12
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# ========================================
# JWT Configuration
# ========================================
# Generate secure keys: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRE_IN=7d
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-this-in-production
JWT_REFRESH_EXPIRE_IN=30d
RESET_TOKEN_EXPIRE_TIME=10

# ========================================
# Email Configuration
# ========================================
EMAIL_HEADER_NAME=Your App Name
EMAIL_FROM=noreply@yourapp.com
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-email-app-password

# Note: For Gmail, use App Password instead of regular password
# Enable 2FA and create app password at: https://myaccount.google.com/apppasswords

# ========================================
# Express Session
# ========================================
EXPRESS_SESSION_SECRET_KEY=your-session-secret-key-change-this

# ========================================
# Socket.IO Configuration
# ========================================
SOCKET_PORT=5001

# ========================================
# Optional: Social Authentication
# ========================================
# Google OAuth 2.0
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:5000/api/v1/auth/google/callback

# Facebook OAuth
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=

# ========================================
# Optional: Twilio (SMS Service)
# ========================================
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# ========================================
# Optional: Stripe (Payment Gateway)
# ========================================
STRIPE_SECRET_KEY=
STRIPE_PAYMENT_SUCCESS_URL=http://localhost:3000/payment/success
STRIPE_WEBHOOK_SECRET=
STRIPE_WEBHOOK_URL=http://localhost:5000/api/v1/webhook/stripe
STRIPE_PRODUCT_ID=

# ========================================
# Instructions
# ========================================
# 1. Copy this file to .env
# 2. Replace all placeholder values with your actual credentials
# 3. Never commit .env file to version control
# 4. Keep this file secure and private

# ========================================
# AWS S3 Configuration (File Uploads)
# ========================================
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
AWS_REGION=ap-south-1
AWS_S3_BUCKET_NAME=your-bucket-name
